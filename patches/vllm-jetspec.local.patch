-prepend_ld_path "${CUDA_HOME:-}/lib64"
+# JETSPEC-REPRO: do NOT prepend the CUDA toolkit lib64 — torch must use its bundled cu128 runtime
+# libs. CUDA_HOME (12.9 toolkit) is for flashinfer's nvcc/headers (compile) only; prepending its
+# lib64 shadowed torch's libcublas/cudart -> CUBLAS_STATUS_INVALID_VALUE on plain GEMMs.
+# prepend_ld_path "${CUDA_HOME:-}/lib64"
 prepend_ld_path "/usr/local/cuda/compat/lib.real"
 prepend_ld_path "/usr/local/cuda/compat/lib"
 prepend_ld_path "/usr/local/nvidia/lib64"
