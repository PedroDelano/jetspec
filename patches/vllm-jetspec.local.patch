diff --git a/examples/offline_inference/dflash_profiling.py b/examples/offline_inference/dflash_profiling.py
index b551760c5d8..dfad6ee7861 100644
--- a/examples/offline_inference/dflash_profiling.py
+++ b/examples/offline_inference/dflash_profiling.py
@@ -1362,6 +1362,11 @@ def run_native_profile(
         profiler_config=profiler_config,
         disable_log_stats=False,
     )
+    # sm_120 (Blackwell) + nvcc 12.1: the auto-selected FlashInfer CUTLASS MoE JIT-compiles
+    # for sm_120 via nvcc, which 12.1 cannot target (needs >=12.9) -> RuntimeError.
+    # Force the Triton fused-MoE backend (Triton JIT via ptxas, no nvcc). Explicit, logged
+    # kernel choice; decoding stays lossless. Override with JETSPEC_MOE_BACKEND.
+    llm_kwargs["moe_backend"] = os.environ.get("JETSPEC_MOE_BACKEND", "triton")
     if args.enable_expert_parallel:
         llm_kwargs["enable_expert_parallel"] = True
     if args.disable_cascade_attn:
diff --git a/examples/offline_inference/jetspec_profiling_math500_tree_budget_bsz_sweep.sh b/examples/offline_inference/jetspec_profiling_math500_tree_budget_bsz_sweep.sh
index e7e86c6c862..88db399bd69 100755
--- a/examples/offline_inference/jetspec_profiling_math500_tree_budget_bsz_sweep.sh
+++ b/examples/offline_inference/jetspec_profiling_math500_tree_budget_bsz_sweep.sh
@@ -26,7 +26,10 @@ prepend_ld_path() {
     export LD_LIBRARY_PATH="${path}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
   fi
 }
-prepend_ld_path "${CUDA_HOME:-}/lib64"
+# JETSPEC-REPRO: do NOT prepend the CUDA toolkit lib64 — torch must use its bundled cu128 runtime
+# libs. CUDA_HOME (12.9 toolkit) is for flashinfer's nvcc/headers (compile) only; prepending its
+# lib64 shadowed torch's libcublas/cudart -> CUBLAS_STATUS_INVALID_VALUE on plain GEMMs.
+# prepend_ld_path "${CUDA_HOME:-}/lib64"
 prepend_ld_path "/usr/local/cuda/compat/lib.real"
 prepend_ld_path "/usr/local/cuda/compat/lib"
 prepend_ld_path "/usr/local/nvidia/lib64"
